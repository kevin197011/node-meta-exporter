# JumpServer connection settings
JUMPSERVER_URL=https://jms.example.com
JUMPSERVER_ACCESS_KEY_ID=your-access-key-id
JUMPSERVER_ACCESS_KEY_SECRET=your-access-key-secret

# JumpServer organization ID (default: all orgs)
# JUMPSERVER_ORG_ID=00000000-0000-0000-0000-000000000002

# Exporter settings
LISTEN_ADDRESS=:9101
METRICS_PATH=/metrics
SCRAPE_INTERVAL=5m
REQUEST_TIMEOUT=30s
PAGE_SIZE=100
ACTIVE_ONLY=false # Set to "true" to fetch only active hosts

# Set to "true" to skip TLS verification (not recommended for production)
TLS_INSECURE_SKIP_VERIFY=false

# Set to "production" for JSON log format
ENV=production
